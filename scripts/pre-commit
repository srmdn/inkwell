#!/usr/bin/env sh
# Pre-commit hook: blocks AI attribution lines, sensitive data, and lint errors.
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
# Skip quality checks only (not security checks):
#   SKIP_LINT=1 git commit
set -eu

PASS=0

# ── 1. AI attribution check ────────────────────────────────────────────────────

COMMIT_MSG_FILE=".git/COMMIT_EDITMSG"

if [ -f "$COMMIT_MSG_FILE" ]; then
  AI_PATTERN="(Co-authored-by:[[:space:]]*(Claude|ChatGPT)|Generated with Claude Code|Generated by[[:space:]].+)"
  if grep -E "$AI_PATTERN" "$COMMIT_MSG_FILE" >/dev/null 2>&1; then
    echo "[pre-commit] Blocked: banned AI attribution line found in commit message."
    echo
    echo "Remove these lines before committing:"
    grep -En "$AI_PATTERN" "$COMMIT_MSG_FILE" | sed 's/^/  /'
    echo
    echo "See docs/AI-COMMIT-CLEANUP.md for cleanup steps."
    PASS=1
  fi
fi

# ── 2. .env file check ────────────────────────────────────────────────────────

ENV_FILES=$(git diff --cached --name-only | grep -E '(^|/)\.env$|(^|/)\.env\.' | grep -v '\.env\.example$' || true)
if [ -n "$ENV_FILES" ]; then
  echo "[pre-commit] Blocked: .env file(s) staged for commit:"
  echo "$ENV_FILES" | sed 's/^/  /'
  echo
  echo "Add to .gitignore and unstage: git restore --staged <file>"
  PASS=1
fi

# ── 3. Sensitive filename check ───────────────────────────────────────────────

SENSITIVE_FILES=$(git diff --cached --name-only | grep -iE '\.(pem|key|p12|pfx|pkcs12|cert)$|(^|/)(credentials|secrets)(\.[a-z]+)?$' || true)
if [ -n "$SENSITIVE_FILES" ]; then
  echo "[pre-commit] Blocked: sensitive file(s) staged for commit:"
  echo "$SENSITIVE_FILES" | sed 's/^/  /'
  echo
  echo "Unstage: git restore --staged <file>"
  PASS=1
fi

# ── 4. Hardcoded secret pattern check ────────────────────────────────────────

SECRET_PATTERN="(password|passwd|secret|api_key|apikey|access_token|auth_token|private_key)[[:space:]]*[:=][[:space:]]*['\"][^'\"]{6,}['\"]"
MATCHED=$(git diff --cached -- '*.go' '*.ts' '*.tsx' '*.js' '*.jsx' | grep '^+' | grep -iE "$SECRET_PATTERN" || true)
if [ -n "$MATCHED" ]; then
  echo "[pre-commit] Warning: possible hardcoded secret detected in staged changes:"
  echo "$MATCHED" | sed 's/^/  /' | head -10
  echo
  echo "Review the above. If intentional, use environment variables instead."
  echo "If a false positive, proceed with: git commit --no-verify (use sparingly)."
  PASS=1
fi

# ── 5. Code quality checks ────────────────────────────────────────────────────
# Skip with: SKIP_LINT=1 git commit

if [ "${SKIP_LINT:-0}" != "1" ]; then

  # Go backend
  if [ -f "go.mod" ]; then
    GO_BIN=$(command -v go 2>/dev/null || echo "/usr/local/go/bin/go")
    echo "[pre-commit] Running go vet..."
    if ! "$GO_BIN" vet ./... 2>&1; then
      echo "[pre-commit] Blocked: go vet failed."
      PASS=1
    fi

    if command -v golangci-lint >/dev/null 2>&1; then
      echo "[pre-commit] Running golangci-lint..."
      if ! golangci-lint run ./... 2>&1; then
        echo "[pre-commit] Blocked: golangci-lint failed."
        PASS=1
      fi
    fi

    GOFMT_BIN=$(command -v gofmt 2>/dev/null || echo "/usr/local/go/bin/gofmt")
    FMT=$("$GOFMT_BIN" -l . 2>/dev/null || true)
    if [ -n "$FMT" ]; then
      echo "[pre-commit] Blocked: unformatted Go files (run gofmt -w .):"
      echo "$FMT" | sed 's/^/  /'
      PASS=1
    fi
  fi

  # Admin UI (admin-ui/package.json)
  if [ -f "admin-ui/package.json" ]; then
    if node -e "const p=require('./admin-ui/package.json'); process.exit(p.scripts&&p.scripts.lint?0:1)" 2>/dev/null; then
      echo "[pre-commit] Running admin-ui lint..."
      if ! (cd admin-ui && npm run lint) 2>&1; then
        echo "[pre-commit] Blocked: admin-ui lint failed."
        PASS=1
      fi
    fi
  fi

fi

# ── Result ────────────────────────────────────────────────────────────────────

exit $PASS
